# Copy this file to .env and fill in your values (NEVER commit .env)

# OPTION A (easier): path to downloaded service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# OPTION B: entire JSON as one line (used on GitHub Actions secrets)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"job-alert-system-74a27",...}

# Upwork RSS feed URL
UPWORK_RSS_URL=https://www.upwork.com/ab/feed/jobs/rss?q=react+native&sort=recency

# LinkedIn job search URL
LINKEDIN_SEARCH_URL=https://www.linkedin.com/jobs/search/?keywords=react%20native&sortBy=DD

# LinkedIn li_at cookie (from browser DevTools → Application → Cookies)
LINKEDIN_LI_AT=AQEDAUhW-J8A8SOAAAABlXYpKDUAAAGe79Y0ik4ANjeYjd-Y02ZXojr8Re8JuB42HxfIzGDgLXOAvdrp3HpUwiSyWsNZqDROZOsTMXpg2o5yQ4p_aV4a2nJEyzKl1Gngd6FtHFQzzA52w9rg-skhL1b4

# Optional
# KEYWORD_FILTER=react native
# MAX_JOBS_PER_RUN=50
