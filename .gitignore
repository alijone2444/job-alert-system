# .env is committed (no live secret in it). The Firebase service-account key is
# NOT committed — a key in a public repo gets auto-revoked by Google. It lives in
# the GitHub Secret FIREBASE_SERVICE_ACCOUNT (CI) and a local file (dev).
service-account*.json
backend/service-account*.json

# Android release signing key (back this up separately, never commit)
mobile/android/app/jobalert-release.keystore

# Dependencies (Har folder ki node_modules)
**/node_modules/
node_modules/

# Logs and OS files
*.log
.DS_Store
Thumbs.db

# Android Specific (Mobile folder ke andar)
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/local.properties
job-alert-system-*-firebase-adminsdk-*.json
