# Copy this file to .env and fill in your values (NEVER commit .env)

# OPTION A (easier): path to downloaded service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# OPTION B: entire JSON as one line (used on GitHub Actions secrets)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"job-alert-system-74a27",...}

# Upwork is parked — its public RSS is dead (HTTP 410) and search is
# Cloudflare-blocked. Set UPWORK_ENABLED=true only once a working source
# (official Upwork API / a scraper service) is wired up.
UPWORK_ENABLED=false
UPWORK_RSS_URL=https://www.upwork.com/ab/feed/jobs/rss?q=react+native&sort=recency

# LinkedIn job search URL — THIS is your MAIN keyword control.
# The `keywords=` value is searched by LinkedIn across the FULL job posting,
# INCLUDING the description — so a job that mentions these skills anywhere shows.
# Supports boolean operators: OR, AND, "quoted phrases", ().
#   keywords = ("react native" OR "react.js" OR reactjs OR mern OR "node.js" OR
#     "express.js" OR mongodb OR "three.js" OR "babylon.js" OR "next.js" OR redux
#     OR zustand OR "tensorflow.js" OR yolov5 OR "computer vision" OR nlp OR
#     "hugging face" OR pytorch OR "ai engineer" OR "junior ai" OR
#     "machine learning" OR firebase OR flutter)
# Other params:
#   - f_E=1,2,3,4   -> experience: internship/entry/associate/mid-senior
#                      (excludes Director/Executive — tuned for ~2 yrs exp)
#   - f_TPR / sortBy -> defaults; overridden by the app's filter settings
# The backend uses LinkedIn's public guest endpoint, so li_at is NOT required.
# (now a code default in config.js) LINKEDIN_SEARCH_URL=https://www.linkedin.com/jobs/search/?keywords=(%22react%20native%22%20OR%20%22react.js%22%20OR%20reactjs%20OR%20mern%20OR%20%22node.js%22%20OR%20%22express.js%22%20OR%20mongodb%20OR%20%22three.js%22%20OR%20%22babylon.js%22%20OR%20webgl%20OR%20%22next.js%22%20OR%20redux%20OR%20zustand%20OR%20%22tensorflow.js%22%20OR%20yolov5%20OR%20%22computer%20vision%22%20OR%20nlp%20OR%20%22hugging%20face%22%20OR%20pytorch%20OR%20%22ai%20engineer%22%20OR%20%22junior%20ai%22%20OR%20%22machine%20learning%22%20OR%20firebase%20OR%20flutter)&f_E=1,2,3,4&f_TPR=r86400&sortBy=DD

# Restrict to specific countries by LinkedIn geoId (each searched + merged).
# Pakistan=101022442, US=103644278, UK=101165590, Canada=101174742,
# Germany=101282230, UAE=104305776, India=102713980. Blank = worldwide.
LINKEDIN_GEO_IDS=101022442,103644278,101165590,101174742,101282230

# Accuracy gate — client-side filter on the job TITLE. Tuned for a MERN / React
# Native / Node / .NET / AI engineer. Requires a RELEVANT stack/role term (NOT
# just the bare word "developer", so "WordPress Developer" / "Game Developer"
# are dropped), and excludes clear noise (wordpress, game, qa, marketing, etc.).
# (now a code default in config.js) KEYWORD_FILTER=("react native" OR "react.js" OR reactjs OR react OR mern OR "node.js" OR nodejs OR node OR express OR mongodb OR "next.js" OR nextjs OR redux OR zustand OR typescript OR javascript OR "full stack" OR "full-stack" OR fullstack OR "front end" OR "front-end" OR frontend OR "back end" OR backend OR "web developer" OR "software engineer" OR "software developer" OR ".net" OR dotnet OR "asp.net" OR "c#" OR "three.js" OR threejs OR webgl OR "ai engineer" OR "ml engineer" OR "machine learning" OR "artificial intelligence" OR "ai developer" OR "generative ai" OR "gen ai" OR genai OR llm OR "computer vision" OR "deep learning" OR "data scientist" OR mlops OR aws OR mobile OR sde) NOT (wordpress OR php OR laravel OR drupal OR magento OR shopify OR wix OR webflow OR game OR gaming OR unity OR unreal OR godot OR roblox OR salesforce OR servicenow OR sap OR sharepoint OR "power bi" OR tableau OR odoo OR "business analyst" OR "data entry" OR qa OR sdet OR "quality assurance" OR tester OR mechanical OR civil OR electrical OR electronics OR hardware OR embedded OR firmware OR "network engineer" OR sysadmin OR sales OR marketing OR seo OR recruiter OR "project manager" OR "scrum master" OR director OR "vice president" OR "head of" OR cto OR "engineering manager" OR "user acquisition" OR aso OR sound OR video OR instructor OR intern OR internship)

# Optional
# MAX_JOBS_PER_RUN=50

# Optional
# MAX_JOBS_PER_RUN=50
